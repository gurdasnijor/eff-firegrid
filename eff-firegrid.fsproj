<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>eff_firegrid</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="src/S2/Interop.fs" />
    <Compile Include="src/S2/Errors.fs" />
    <Compile Include="src/S2/Client.fs" />
    <Compile Include="src/S2/Cli.fs" />
    <Compile Include="src/S2/Patterns.fs" />
    <Compile Include="src/Foundation/StreamLog.fs" />
    <Compile Include="src/Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="5.1.0" />
  </ItemGroup>

</Project>
